{
  "name": "floatpaste",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "preflight": "pnpm build && pnpm test:rust:win",
    "install:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/win-pnpm.ps1 install",
    "dev:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/win-pnpm.ps1 dev",
    "build:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/win-pnpm.ps1 build",
    "tauri:dev:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/win-pnpm.ps1 tauri dev",
    "tauri:build:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/win-pnpm.ps1 tauri build",
    "test:rust:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/win-cargo.ps1 test",
    "preview": "vite preview",
    "tauri": "tauri",
    "release:portable": "powershell -ExecutionPolicy Bypass -File scripts/build-portable.ps1"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.80.7",
    "@tauri-apps/api": "^2.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
