{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "manager-capability",
  "description": "资料库窗口权限",
  "windows": ["manager"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus"
  ]
}
