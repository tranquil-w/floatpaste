{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FloatPaste",
  "version": "0.1.0-beta.3",
  "identifier": "com.floatpaste",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "manager",
        "title": "FloatPaste / 浮贴",
        "width": 1200,
        "height": 760,
        "resizable": true,
        "center": true,
        "visible": false
      },
      {
        "label": "picker",
        "title": "FloatPaste Picker",
        "width": 360,
        "height": 420,
        "minWidth": 256,
        "minHeight": 280,
        "resizable": true,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "capabilities": [
        "background-capability",
        "manager-capability",
        "picker-capability"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}