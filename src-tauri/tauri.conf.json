{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FloatPaste",
  "version": "0.2.0-beta.3",
  "identifier": "com.floatpaste",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "manager",
        "title": "FloatPaste · 设置",
        "width": 920,
        "height": 760,
        "minWidth": 880,
        "resizable": true,
        "center": true,
        "visible": false
      },
      {
        "label": "picker",
        "title": "FloatPaste · 速贴",
        "width": 360,
        "height": 420,
        "minWidth": 256,
        "minHeight": 280,
        "resizable": true,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false
      },
      {
        "label": "workbench",
        "title": "FloatPaste · 搜索",
        "width": 780,
        "height": 420,
        "minWidth": 620,
        "resizable": false,
        "center": true,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": false
      },
      {
        "label": "editor",
        "title": "FloatPaste · 编辑",
        "width": 800,
        "height": 600,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "center": true,
        "visible": false,
        "decorations": true,
        "alwaysOnTop": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "$HOME/.floatpaste-data/**"
        ]
      },
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'",
      "capabilities": [
        "background-capability",
        "settings-capability",
        "picker-capability",
        "search-capability",
        "editor-capability",
        "tooltip-capability"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}

