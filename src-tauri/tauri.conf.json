{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FloatPaste",
  "version": "0.1.0",
  "identifier": "com.floatpaste.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "manager",
        "title": "FloatPaste / 浮贴",
        "width": 1480,
        "height": 920,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "capabilities": [
        "background-capability",
        "manager-capability",
        "picker-capability"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
